# Copy to .env and adjust (optional). Values below match docker-compose defaults.

# JVM heap size in megabytes (single dev node)
ELASTIC_HEAP_MB=512

# Published host port for Elasticsearch HTTP API
ELASTIC_HTTP_HOST_PORT=59200

# Cluster display name
ELASTIC_CLUSTER_NAME=many-faces-dev

# Published host port for search-worker gRPC (grpcurl / backend dev from host)
SEARCH_WORKER_GRPC_HOST_PORT=59202

# Optional shared secret enforced by the worker unary interceptor (leave empty for trusted dev-only networks)
SEARCH_WORKER_EXPECTED_TOKEN=

# In-container overrides (normally set in docker-compose.yml; listed here for documentation)
# SEARCH_WORKER_GRPC_LISTEN=:50052
# SEARCH_WORKER_ELASTICSEARCH_URLS=http://elasticsearch:9200

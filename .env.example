# Copy to .env and adjust (optional). Values below match docker-compose defaults.

# JVM heap size in megabytes (single dev node)
ELASTIC_HEAP_MB=512

# Published host port for Elasticsearch HTTP API
ELASTIC_HTTP_HOST_PORT=59200

# Cluster display name
ELASTIC_CLUSTER_NAME=many-faces-dev

# Published host port for search-worker gRPC (grpcurl / backend dev from host)
SEARCH_WORKER_GRPC_HOST_PORT=59202

# Optional shared secret enforced by the worker unary interceptor (leave empty for trusted dev-only networks)
SEARCH_WORKER_EXPECTED_TOKEN=

# Optional gRPC TLS (both cert and key required when enabling). Optional mTLS: set client CA PEM to require client certs.
# SEARCH_WORKER_GRPC_TLS_CERT_FILE=/run/grpc-tls/server.crt
# SEARCH_WORKER_GRPC_TLS_KEY_FILE=/run/grpc-tls/server.key
# SEARCH_WORKER_GRPC_MTLS_CLIENT_CA_FILE=/run/grpc-tls/client-ca.crt

# In-container overrides (normally set in docker-compose.yml; listed here for documentation)
# SEARCH_WORKER_GRPC_LISTEN=:50052
# SEARCH_WORKER_ELASTICSEARCH_URLS=http://elasticsearch:9200

# Operator-AI RAG knowledge index settings (operator-ai-rag-retrieval-refactor v1).
# Single source of truth for the dense_vector mapping dims, the vector_dim drift guard, and the
# KnowledgeIndexStatus readiness check. Defaults shown match nomic-embed-text + the 61 stat bundles.
# OPERATOR_AI_EMBED_DIM=768
# OPERATOR_AI_EMBED_MODEL=nomic-embed-text
# OPERATOR_AI_EXPECTED_DOC_COUNT=61
